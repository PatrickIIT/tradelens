# tradelens/.env
# Root-level environment variables — shared reference.
# Copy this to backend/.env for the Express server.
# The frontend has its own frontend/.env (VITE_ prefix only).
# NEVER commit this file to Git — it is listed in .gitignore.

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=a-strong-random-secret-min-32-chars

# ── Africa's Talking (SMS notifications) ─────────────────────────────────────
AFRICAS_TALKING_API_KEY=atsk_d5819c457354e4780d75d2a7712f4e8400985435fda6a41530ebc62976f6090f8b7dc8f0
AFRICAS_TALKING_USERNAME=sandbox

# ── Backend server ────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Frontend URL (CORS whitelist) ─────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
