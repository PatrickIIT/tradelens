# ================================================
# TradeLens — Environment Variables (Example)
# Tanzania–Zambia Corridor | IIT Madras Zanzibar 2026
# ================================================

# ─── Supabase Configuration ─────────────────────────────
# Get these from your Supabase Project → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_KEY=eyJhbGciOi...   # Service Role Key (Server-side only)

# ─── Frontend URL (for CORS) ────────────────────────────
# Used by backend to allow requests from frontend
FRONTEND_URL=http://localhost:5173

# ─── Africa's Talking SMS (Notifications) ───────────────
# Get these from https://account.africastalking.com/
AFRICAS_TALKING_USERNAME=sandbox          # Use "sandbox" for testing
AFRICAS_TALKING_API_KEY=your_sandbox_key_here

# ─── JWT Secret (Fallback - Supabase handles most auth) ──
JWT_SECRET=your_super_long_random_secret_key_here_min_32_chars

# ─── Optional: Node Environment ─────────────────────────
NODE_ENV=development

# ================================================
# Instructions:
# 1. Copy this file to `.env` in the root folder
# 2. Fill in the actual values
# 3. Never commit the real .env file to Git
# ================================================
